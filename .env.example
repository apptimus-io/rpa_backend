NODE_ENV=development
PORT=4000
API_PUBLIC_URL=http://localhost:4000
FRONTEND_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW="1 minute"
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW="1 minute"
UPLOAD_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_WINDOW="1 minute"
DOCUMENT_MAX_UPLOAD_BYTES=26214400

# MySQL / Sequelize
# Either set DATABASE_URL or the DB_* fields below.
# DATABASE_URL=mysql://replace-with-db-user:replace-with-db-password@localhost:3306/rpa_db
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rpa_db
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_CONNECT_ON_START=false
DB_SYNC_ON_START=false
DB_ALLOW_DEMO_FALLBACK=false
DB_CONNECT_TIMEOUT_MS=5000

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Auth token signing
ACCESS_TOKEN_SECRET=replace-with-long-random-access-token-secret
ACCESS_TOKEN_TTL=8h
REFRESH_TOKEN_SECRET=replace-with-long-random-refresh-token-secret
PASSWORD_RESET_TOKEN_SECRET=replace-with-long-random-password-reset-secret

# Encrypted portal credential storage
# Use a long random value. Production must set this; do not commit real keys.
CREDENTIAL_ENCRYPTION_KEY=replace-with-long-random-credential-encryption-key

# Internal Python agent API access
INTERNAL_AGENT_TOKEN=replace-with-long-random-agent-token
AGENT_AUTO_RUN=false
# Optional local auto-run settings (only if backend should spawn Python agent):
# AGENT_WORKDIR=C:/path/to/browser-agent-agent
# AGENT_PYTHON_PATH=C:/path/to/browser-agent-agent/.venv/Scripts/python.exe
METRICS_TOKEN=replace-with-long-random-metrics-token

# Cloudinary document/screenshot storage
CLOUDINARY_URL=cloudinary://replace-with-api-key:replace-with-api-secret@replace-with-cloud-name
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
CLOUDINARY_UPLOAD_PRESET=replace-with-upload-preset

# Gemini fallback for changed portal DOM
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_VISION_MODEL=gemini-3-flash-preview
GEMINI_VLM_ENABLED=true

# Email notifications
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=notifications@example.com
MAIL_PASSWORD=replace-with-mail-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=notifications@example.com
MAIL_FROM_NAME="Broker AI Flow"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASSWORD=replace-with-smtp-password
NOTIFICATION_FROM_EMAIL=notifications@example.com

# Development-only seed credentials
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=replace-with-local-seed-password
