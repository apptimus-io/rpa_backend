{
  "name": "@rpa/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.json",
    "vercel-build": "npm install mysql2 && npm run db:migrate && npm run db:seed",
    "start": "tsx server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run test:smoke",
    "test:smoke": "tsx tests/credentials.unit.ts && tsx tests/queue.unit.ts && tsx tests/cloudinary.unit.ts && tsx tests/smoke.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "dashboard:aggregate": "tsx src/jobs/dashboard-aggregation.job.ts",
    "sla:check": "tsx src/jobs/escalation-sla.job.ts",
    "gemini:prompt-review": "tsx src/jobs/gemini-prompt-review.job.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.4.0",
    "mysql2": "^3.14.1",
    "pino": "^9.7.0",
    "playwright": "^1.60.0",
    "sequelize": "^6.37.7",
    "tsx": "^4.19.4",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3"
  }
}
